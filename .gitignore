# === Valin v2 .gitignore ===

# Entorno virtual (creado por LANZAR_APP.bat)
venv/

# Cache de Python
__pycache__/
*.pyc
.pytest_cache/

# Base de datos local y copias de seguridad
instance/

# Configuracion local del PC (cada PC tiene la suya)
config.json

# Variables de entorno (no se usan, pero por si acaso)
.env

# IDEs
.vscode/
.idea/
*.code-workspace

# Archivos del sistema
Thumbs.db
Desktop.ini
.DS_Store
